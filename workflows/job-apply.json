    {
      "parameters": {
        "jsCode": "function domainOf(url) {\n  try {\n    const u = new URL(url);\n    return u.hostname.toLowerCase();\n  } catch {\n    return '';\n  }\n}\n\nconst j = item.json;\nconst applyUrl = j.apply_url || j.job_url || '';\nconst host = domainOf(applyUrl);\n\nconst allowlistCsv = $('Job Apply Config').item.json.greenhouseAllowlist || '';\nconst allowlist = allowlistCsv.split(',').map(s => s.trim()).filter(Boolean);\nconst isGreenhouse = allowlist.some(d => host.includes(d));\n\n// Human-approved rows should be submitted even if domain matching fails.\nconst wantsSubmit = String(j.application_status || '').toLowerCase() === 'approved' || isGreenhouse;\n\nconst ats_type = isGreenhouse ? 'greenhouse' : 'unknown';\nconst application_mode = wantsSubmit && isGreenhouse ? 'auto_submit' : 'needs_review';\n\nconst action = wantsSubmit ? 'submit' : 'draft';\n\nreturn [{\n  json: {\n    ...j,\n    ats_type,\n    application_mode,\n    action\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",

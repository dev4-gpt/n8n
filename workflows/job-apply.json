      "name": "rtrvr.ai submit (placeholder)"
    },
    {
      "parameters": {
        "jsCode": "const decide = $('Decide submit vs draft').item.json;\nconst resp = item.json;\n\nconst ok = resp?.success === true || resp?.status === 'submitted' || resp?.application_status === 'submitted' || resp?.submitted === true;\n\nconst missing = resp?.missing_fields || resp?.missingFields || [];\nconst missingStr = Array.isArray(missing) ? missing.join(',') : (missing ? String(missing) : '');\n\nconst errorLast = ok ? '' : (resp?.error || resp?.message || resp?.detail || 'rtrvr submit failed');\n\nconst lastAttemptAt = new Date().toISOString();\n\nreturn [\n  {\n    json: {\n      job_hash: decide.job_hash,\n      job_source: decide.job_source,\n      job_url: decide.job_url,\n      apply_url: decide.apply_url,\n      company: decide.company,\n      title: decide.title,\n      location: decide.location,\n      posted_at: decide.posted_at,\n      ats_type: decide.ats_type,\n      application_mode: decide.application_mode,\n      fit_verdict: decide.fit_verdict,\n      fit_reason: decide.fit_reason,\n      fit_score: decide.fit_score,\n      resume_doc_url: decide.resume_doc_url,\n      cover_letter_url: decide.cover_letter_url,\n      application_status: ok ? 'submitted' : 'failed',\n      missing_fields: ok ? missingStr : missingStr || 'submit_failed',\n      approved_by: '',\n      last_attempt_at: lastAttemptAt,\n      attempt_count: (Number(decide.attempt_count || 0) || 0) + 1,\n      error_last: errorLast,\n      created_at: decide.created_at || lastAttemptAt,\n      updated_at: lastAttemptAt\n    }\n  }\n];"
      },

        "url": "={{ $('Job Apply Config').item.json.rtrvrApplyUrl }}",
        "authentication": "none",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"job_hash\": \"{{$json.job_hash}}\",\n  \"apply_url\": \"{{$json.apply_url}}\",\n  \"ats_type\": \"{{$json.ats_type}}\",\n  \"mode\": \"submit\",\n  \"resume_doc_url\": \"{{$json.resume_doc_url}}\",\n  \"cover_letter_url\": \"{{$json.cover_letter_url}}\",\n  \"applicant\": {\n    \"email\": \"{{$('Job Apply Config').item.json.personalEmail}}\",\n    \"phone\": \"{{$('Job Apply Config').item.json.personalPhone}}\",\n    \"linkedin\": \"{{$('Job Apply Config').item.json.personalLinkedIn}}\",\n    \"github\": \"{{$('Job Apply Config').item.json.personalGithub}}\"\n  }\n}",
        "options": {}
      },

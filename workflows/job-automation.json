        "jsCode": "const cfg = $('Job Search URL').item.json;\n\nconst personal = {\n  email: cfg.personalEmail || 'REPLACE_ME',\n  phone: cfg.personalPhone || 'REPLACE_ME',\n  linkedin: cfg.personalLinkedIn || 'https://www.linkedin.com/in/REPLACE_ME/',\n  credentials: cfg.personalCredentials || 'https://REPLACE_ME/',\n  github: cfg.personalGithub || 'https://github.com/REPLACE_ME',\n  schoolGithub: cfg.personalSchoolGithub || 'https://github.com/REPLACE_ME'\n};\n\nconst resumeHeader = [\n  `Email: ${personal.email}`,\n  `Phone: ${personal.phone}`,\n  `[LinkedIn](${personal.linkedin})`,\n  `[Credentials](${personal.credentials})`,\n  `[GitHub](${personal.github})`,\n  `[School GitHub](${personal.schoolGithub})`\n].join(' | ');\n\nreturn $input.all().map(item => ({\n  json: {\n    ...item.json,\n    resumeHeader\n  }\n}));"

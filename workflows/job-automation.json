    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const j = item.json;\n  \n  if (j.error) {\n    // Handle 429/error items gracefully\n    return {\n      json: {\n        ...j,\n        verdict: null,\n        reason: 'API rate limited - retry later',\n        rawModelOutput: null\n      }\n    };\n  }\n\n  const raw = j.choices[0].message.content;  // Correct path\n  let parsed;\n  \n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    return {\n      json: {\n        ...j,\n        verdict: null,\n        reason: `Parse error: ${e.message}`,\n        rawModelOutput: raw\n      }\n    };\n  }\n\n  return {\n    json: {\n      ...j,\n      verdict: parsed.verdict,\n      reason: parsed.reason,\n      rawModelOutput: raw  // Keep for debugging\n    }\n  };\n});\n"

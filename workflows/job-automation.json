        "jsonBody": "={\n  \"model\": \"qwen/qwen3-coder-480b-a35b-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a helpful, intelligent, expert resume writing assistant that drafts high converting resumes based on jobs. Given the candidate's existing resume and a job description, rewrite the resume to better highlight relevant skills and experience. This resume will be added to a Google Doc, so write it in HTML format that I can easily copy/paste. Do not output any backticks (no ```). Your first characters should be <html>. Never invent degrees, experience, or skills\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(\n        \"##Overview\\nI'm looking for jobs. Your task is to customize a provided resume using a provided job description. \\n\\n\" + \"##Job Description\\n\" + $('Scrape Jobs').item.json.descriptionText + \"\\n\\n\" +\n        \"##My Current Resume\\n\" + $('Get resume').item.json.content + \"\\n\\n\" +\n        \"Respond only with the customized, updated resume in HTML format. No explanations, no markdown, no JSON.\"\n      ) }}\n    }\n  ],\n  \"temperature\": 0.3,\n  \"top_p\": 0.8,\n  \"max_tokens\": 4096,\n  \"stream\": false\n}",

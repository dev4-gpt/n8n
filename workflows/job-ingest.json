      "name": "Fetch SimplifyJobs README"
    },
    {
      "parameters": {
        "jsCode": "function extractText(input) {\n  if (typeof input === 'string') return input;\n  return input?.body ?? input?.data ?? input?.text ?? input?.content ?? '';\n}\n\nfunction parseMarkdownTable(text) {\n  const lines = String(text || '').split('\\n');\n  const jobs = [];\n\n  for (const rawLine of lines) {\n    const line = rawLine.trim();\n    if (!line.startsWith('|')) continue;\n    if (line.includes('---')) continue;\n    if (!/https?:\\/\\//i.test(line)) continue;\n\n    const urlMatches = [...line.matchAll(/\\((https?:\\/\\/[^)]+)\\)/g)].map(m => m[1]);\n    const urlFallback = [...line.matchAll(/(https?:\\/\\/[^\\s\\)]+)/g)].map(m => m[1]);\n    const apply_url = urlMatches[0] || urlFallback[0];\n    if (!apply_url) continue;\n\n    const lineNoLinks = line.replace(/\\[([^\\]]+)\\]\\((https?:\\/\\/[^)]+)\\)/g, '$1');\n    const cells = lineNoLinks.split('|').map(c => c.trim()).filter(Boolean);\n\n    const roleRegex = /(intern|internship|engineer|scientist|analyst|developer|research|machine learning|ai|ml|natural language|genai|nlp|quant|data)/i;\n    let title = cells.find(c => roleRegex.test(c)) || cells[1] || cells[0] || '';\n\n    // Company: first cell that isn't obviously a role/location.\n    const locRegex = /(remote|united states|usa|canada|uk|europe|india|singapore|australia|new york|california|massachusetts|texas|boston|seattle)/i;\n    const companyCandidates = cells.filter(c => !roleRegex.test(c) && !locRegex.test(c) && !/https?:\\/\\//i.test(c));\n    const company = companyCandidates[0] || cells[0] || '';\n\n    const location = cells.find(c => locRegex.test(c)) || '';\n\n    jobs.push({\n      job_url: apply_url,\n      apply_url,\n      company,\n      title,\n      location,\n      posted_at: '',\n      job_source: 'github_simplifyjobs'\n    });\n  }\n\n  return jobs;\n}\n\nconst text = extractText($json);\nconst jobs = parseMarkdownTable(text);\n\nreturn jobs.map(j => ({ json: j }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -320,
        360
      ],
      "id": "9d8c7b6a-5f4e-3d2c-1b0a-9f8e7d6c5b4a",
      "name": "Parse SimplifyJobs markdown"
    },
    {
      "parameters": {
        "jsCode": "// Simple hash function (no crypto module - disallowed in n8n cloud)\nfunction simpleHash(str) {\n  let hash = 0;\n  for (let i = 0; i < str.length; i++) {\n    const char = str.charCodeAt(i);\n    hash = ((hash << 5) - hash) + char;\n    hash = hash & hash; // Convert to 32bit integer\n  }\n  // Convert to hex and pad to ensure consistent length\n  return Math.abs(hash).toString(16).padStart(8, '0');\n}\n\nfunction norm(s) {\n  return String(s || '').toLowerCase().trim();\n}\n\nconst now = new Date().toISOString();\nconst seen = new Set();\n\nconst out = [];\n\nfor (const item of items) {\n  const j = item.json || {};\n\n  const canonical = [\n    norm(j.apply_url || j.job_url),\n    norm(j.company),\n    norm(j.title)\n  ].join('|');\n\n  const job_hash = simpleHash(canonical);\n\n  if (seen.has(job_hash)) continue;\n  seen.add(job_hash);\n\n  out.push({\n    json: {\n      job_hash,\n      job_source: j.job_source || '',\n      job_url: j.job_url || '',\n      apply_url: j.apply_url || '',\n      company: j.company || '',\n      title: j.title || '',\n      location: j.location || '',\n      posted_at: j.posted_at || '',\n      ats_type: j.ats_type || 'unknown',\n      application_mode: j.application_mode || 'needs_review',\n      fit_verdict: j.fit_verdict ?? '',\n      fit_reason: j.fit_reason ?? '',\n      fit_score: j.fit_score ?? '',\n      resume_doc_url: j.resume_doc_url ?? '',\n      cover_letter_url: j.cover_letter_url ?? '',\n      application_status: j.application_status || 'new',\n      missing_fields: j.missing_fields || '',\n      approved_by: j.approved_by ?? '',\n      last_attempt_at: j.last_attempt_at ?? '',\n      attempt_count: typeof j.attempt_count === 'number' ? j.attempt_count : 0,\n      error_last: j.error_last ?? '',\n      created_at: j.created_at || now,\n      updated_at: now\n    }\n  });\n}\n\nreturn out;"
      },

    {
      "parameters": {
        "jsCode": "const j = $json;\n\nreturn [\n  {\n    json: {\n      job_source: 'linkedin_apify',\n      job_url: j.link || '',\n      apply_url: j.applyUrl || '',\n      company: j.companyName || '',\n      title: j.title || '',\n      location: j.location || j.locationText || '',\n      posted_at: j.postedAt || '',\n      ats_type: 'unknown',\n      application_mode: 'needs_review',\n      fit_verdict: '',\n      fit_reason: '',\n      fit_score: '',\n      resume_doc_url: '',\n      cover_letter_url: '',\n      application_status: 'new',\n      missing_fields: '',\n      approved_by: '',\n      last_attempt_at: '',\n      attempt_count: 0,\n      error_last: '',\n      created_at: new Date().toISOString(),\n      updated_at: new Date().toISOString()\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -320,
        -280
      ],
      "id": "0f2a7c1c-9c3d-4f1b-a7e4-1b2c3d4e5f6a",
      "name": "Normalize LinkedIn Job"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.speedyapplyReadmeUrl }}"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        -560,
        40
      ],
      "id": "7f6e5d4c-3b2a-1c0d-9e8f-7a6b5c4d3e2f",
      "name": "Fetch speedyapply README"
    },
    {
      "parameters": {
        "jsCode": "function extractText(input) {\n  if (typeof input === 'string') return input;\n  return input?.body ?? input?.data ?? input?.text ?? input?.content ?? '';\n}\n\nfunction parseMarkdownTable(text) {\n  const lines = String(text || '').split('\\n');\n  const jobs = [];\n\n  for (const rawLine of lines) {\n    const line = rawLine.trim();\n    if (!line.startsWith('|')) continue;\n    if (line.includes('---')) continue;\n    if (!/https?:\\/\\//i.test(line)) continue;\n\n    // Extract all URLs from markdown links in the row.\n    const urlMatches = [...line.matchAll(/\\((https?:\\/\\/[^)]+)\\)/g)].map(m => m[1]);\n    const urlFallback = [...line.matchAll(/(https?:\\/\\/[^\\s\\)]+)/g)].map(m => m[1]);\n    const apply_url = urlMatches[0] || urlFallback[0];\n    if (!apply_url) continue;\n\n    // Remove URLs, keep link labels: [label](url) -> label\n    const lineNoLinks = line.replace(/\\[([^\\]]+)\\]\\((https?:\\/\\/[^)]+)\\)/g, '$1');\n    const cells = lineNoLinks.split('|').map(c => c.trim()).filter(Boolean);\n\n    // Heuristic: choose title from likely role keywords, else second cell.\n    const roleRegex = /(intern|internship|engineer|scientist|analyst|developer|research|machine learning|ai|ml|natural language|genai|nlp|quant|data)/i;\n    let title = cells.find(c => roleRegex.test(c)) || cells[1] || cells[0] || '';\n\n    // Heuristic: company is the first non-title cell that doesn't look like a URL.\n    let company = cells.find((c, idx) => idx !== cells.indexOf(title) && !roleRegex.test(c)) || cells[0] || '';\n\n    // Location: first cell that mentions common regions/remote.\n    const locRegex = /(remote|united states|usa|canada|uk|europe|india|singapore|australia|new york|california|massachusetts|texas|boston|seattle)/i;\n    const location = cells.find(c => locRegex.test(c)) || '';\n\n    jobs.push({\n      job_url: apply_url,\n      apply_url,\n      company,\n      title,\n      location,\n      posted_at: '',\n      job_source: 'github_speedyapply'\n    });\n  }\n\n  return jobs;\n}\n\nconst text = extractText($json);\nconst jobs = parseMarkdownTable(text);\n\nreturn jobs.map(j => ({ json: j }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -320,
        40
      ],
      "id": "3c2b1a0d-9e8f-7a6b-5c4d-3e2f1a0b9c8d",
      "name": "Parse speedyapply markdown"

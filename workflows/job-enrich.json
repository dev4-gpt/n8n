        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"qwen/qwen3-coder-480b-a35b-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a helpful, intelligent, expert resume writing assistant that drafts high converting resumes based on jobs. Given the candidate's existing resume and a job context, rewrite the resume to better highlight relevant skills and experience. This resume will be added to a Google Doc, so write it in HTML format that I can easily copy/paste. Do not output any backticks (no ```). Your first characters should be <html>. Never invent degrees, experience, or skills\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(\n        \"##Overview\\nI'm applying to jobs.\\n\\n##Job Context\\nCompany: \" + ($json.company || '') + \"\\nTitle: \" + ($json.title || '') + \"\\nApply URL: \" + ($json.apply_url || '') + \"\\n\\n##My Current Resume\\n\" + ($('Get base resume').item.json.content || '') + \"\\n\\nRespond only with the customized, updated resume in HTML format. No explanations, no markdown, no JSON.\"\n      ) }}\n    }\n  ],\n  \"temperature\": 0.3,\n  \"top_p\": 0.8,\n  \"max_tokens\": 4096,\n  \"stream\": false\n}",
        "options": {}
      },

      "parameters": {
        "method": "POST",
        "url": "https://integrate.api.nvidia.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"qwen/qwen3-coder-480b-a35b-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a job relevance classifier. For each candidate resume + job context, decide if the candidate is a good fit. Reply ONLY with a single JSON object of the form: {\\\"verdict\\\": true or false, \\\"reason\\\": \\\"short explanation\\\"}. No markdown, no extra text.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(\n        \"##My Current Resume\\n\" + ($('Get base resume').item.json.content || '') + \"\\n\\n##Job Context\\nCompany: \" + ($json.company || '') + \"\\nTitle: \" + ($json.title || '') + \"\\nApply URL: \" + ($json.apply_url || '') + \"\\n\\nReturn ONLY JSON with verdict=true/false and reason.\"\n      ) }}\n    }\n  ],\n  \"temperature\": 0.1,\n  \"top_p\": 0.8,\n  \"max_tokens\": 256,\n  \"stream\": false\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        540,
        0
      ],
      "id": "2b3c4d5e-6f70-4b81-9c02-1d2e3f4a5b6c",
      "name": "LLM classify fit",
      "retryOnFail": true,
      "maxTries": 5,
      "waitBetweenTries": 5000,
      "credentials": {
        "openAiApi": {
          "id": "cktBRf5R1YBRHZod",
          "name": "OpenAi account"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const j = item.json;\n\n  const raw = j?.choices?.[0]?.message?.content ?? '';\n  let parsed;\n  try {\n    parsed = JSON.parse(raw);\n  } catch (e) {\n    return {\n      json: {\n        ...j,\n        verdict: null,\n        reason: 'Parse error',\n        rawModelOutput: raw\n      }\n    };\n  }\n\n  return {\n    json: {\n      ...j,\n      verdict: parsed.verdict,\n      reason: parsed.reason,\n      rawModelOutput: raw\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        760,
        0
      ],
      "id": "3c4d5e6f-7081-4c92-ad03-2e3f4a5b6c7d",
